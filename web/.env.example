# Stealth Web — Environment Variables
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. This file (.env.example) is safe to commit.
#
# See web/DEPLOYMENT.md for full configuration details.

# Path to the stealth scanner binary used by the API route.
# For local dev: point to the release build output.
# For production (Vercel): set to the bundled binary path in web/bin/.
VANGUARD_PATH=../core/target/release/stealth

# Temporary directory for scan jobs. Must be writable by the server process.
# Leave blank to use the OS default temp dir.
TEMP_DIR=./tmp/vanguard-scans
